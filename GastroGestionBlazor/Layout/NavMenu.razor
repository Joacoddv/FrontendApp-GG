@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<nav class="sidebar">
    <div class="sidebar-header">
        <img src="images/GastroGestionpeque-removebg-preview-Blanco.png" alt="GastroGestión" class="logo" />
        <div>
            <span class="brand-word">Gastro<span>Gestión</span></span>
            <span class="brand-sub">El pase</span>
        </div>
    </div>
    <ul class="nav flex-column">
        <li class="nav-item">
            <NavLink class="nav-link" href="clientes"><i class="fas fa-users"></i>Clientes</NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link" href="pedidos"><i class="fas fa-receipt"></i>Pedidos</NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link" href="facturas"><i class="fas fa-file-invoice-dollar"></i>Facturas</NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link" href="platos"><i class="fas fa-utensils"></i>Platos</NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link" href="ingredientes"><i class="fas fa-carrot"></i>Ingredientes</NavLink>
        </li>
        <AuthorizeView Roles="Administrador">
            <li class="nav-item">
                <NavLink class="nav-link" href="stock"><i class="fas fa-boxes-stacked"></i>Stock</NavLink>
            </li>
        </AuthorizeView>
        <li class="nav-item">
            <NavLink class="nav-link" href="menu"><i class="fas fa-book-open"></i>Menú</NavLink>
        </li>
        @* Kitchen board — gated to Cocinero and Administrador roles. BAF-08. *@
        <AuthorizeView Roles="Cocinero,Administrador">
            <li class="nav-item">
                <NavLink class="nav-link" href="ordenes-trabajo"><i class="fas fa-fire-burner"></i>Cocina</NavLink>
            </li>
        </AuthorizeView>
    </ul>
    <button class="btn logout-btn" @onclick="HandleLogout"><i class="fas fa-right-from-bracket"></i>Cerrar sesión</button>
    <button class="logout-all-link" @onclick="HandleLogoutAll">en todos los dispositivos</button>
</nav>

@code {
    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: false);
    }

    private async Task HandleLogoutAll()
    {
        var ok = await JS.InvokeAsync<bool>(
            "confirm",
            "¿Cerrar sesión en TODOS los dispositivos? Se revocarán todas tus sesiones activas.");
        if (!ok)
            return;

        await AuthService.LogoutAllAsync();
        Navigation.NavigateTo("/login", forceLoad: false);
    }
}
