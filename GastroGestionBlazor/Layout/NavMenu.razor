@inject IAuthService AuthService
@inject NavigationManager Navigation

<nav class="sidebar">
    <div class="sidebar-header">
        <img src="images/GastroGestionpeque-removebg-preview-Blanco.png" alt="Logo" class="logo" />
    </div>
    <ul class="nav flex-column">
        <li class="nav-item">
            <NavLink class="nav-link" href="clientes">Clientes</NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link" href="pedidos">Pedidos</NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link" href="facturas">Facturas</NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link" href="platos">Platos</NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link" href="ingredientes">Ingredientes</NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link" href="menu">Menu</NavLink>
        </li>
        @* Kitchen board — gated to Cocinero and Administrador roles. BAF-08.
           The actual board page is implemented in Slice C; this entry is nav-only. *@
        <AuthorizeView Roles="Cocinero,Administrador">
            <li class="nav-item">
                <NavLink class="nav-link" href="ordenes-trabajo">Cocina</NavLink>
            </li>
        </AuthorizeView>
    </ul>
    <button class="btn btn-danger logout-btn" @onclick="HandleLogout">Cerrar sesión</button>
</nav>

@code {
    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: false);
    }
}
