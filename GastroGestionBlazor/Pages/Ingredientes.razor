@page "/ingredientes"

@using GastroGestionBlazor.Contracts.Ingredientes
@using GastroGestionBlazor.Contracts.Enums
@using GastroGestionBlazor.Contracts.Common
@using Microsoft.AspNetCore.Authorization
@inject IngredienteService IngredienteService
@inject IJSRuntime JS

<h3>Ingredientes</h3>
<hr class="custom-line" />

<div class="form-row">
    <button class="btn btn-primary" @onclick="AgregarNuevoIngrediente"><i class="fas fa-plus"></i> Nuevo ingrediente</button>
</div>

<div class="search-container">
    <div class="form-group">
        <label for="campoBusqueda">Filtrar por:</label>
        <select id="campoBusqueda" class="form-control">
            <option>Nombre</option>
        </select>
    </div>
    <div class="form-group">
        <label for="valorBusqueda">Valor:</label>
        <input id="valorBusqueda" class="form-control" @bind="searchNombre" placeholder="Buscar por nombre..." />
    </div>
    <div class="form-group">
        <button class="btn btn-secondary" @onclick="BuscarIngredientes">Buscar</button>
    </div>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <p class="text-danger">@errorMessage</p>
}

@if (isLoading)
{
    <p>Cargando...</p>
}
else if (ingredientes.Count == 0)
{
    <p class="text-muted">No hay ingredientes registrados.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Unidad base</th>
                <th>Activo</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ingrediente in ingredientes)
            {
                <tr class="@(ingrediente.Activo ? "" : "text-muted")">
                    <td>@ingrediente.Nombre</td>
                    <td>@ingrediente.UnidadBase</td>
                    <td>
                        @if (ingrediente.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </td>
                    <td class="action-buttons">
                        <button class="btn btn-info btn-sm" @onclick="() => VerDetalle(ingrediente)" title="Ver Detalle"><i class="fas fa-eye"></i></button>
                        <AuthorizeView Roles="Administrador">
                            <button class="btn btn-warning btn-sm" @onclick="() => MostrarEditar(ingrediente)" title="Editar"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarIngrediente(ingrediente.Id)" title="Eliminar"><i class="fas fa-trash"></i></button>
                        </AuthorizeView>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (ingredienteSeleccionado != null)
    {
        <h3>Detalle del ingrediente</h3>
        <div class="detail-container">
            <div class="detail-item">
                <label>Nombre:</label>
                <input value="@ingredienteSeleccionado.Nombre" disabled />
            </div>
            <div class="detail-item">
                <label>Unidad base:</label>
                <input value="@ingredienteSeleccionado.UnidadBase" disabled />
            </div>
            <div class="detail-item">
                <label>Estado:</label>
                <input value="@(ingredienteSeleccionado.Activo ? "Activo" : "Inactivo")" disabled />
            </div>
            <div class="mt-3">
                <button class="btn btn-secondary" @onclick="CerrarDetalle">Cerrar</button>
            </div>
        </div>
        <div class="footer-spacing"></div>
    }

    @if (showEditForm && ingredienteEnEdicion != null)
    {
        <h3>Editar ingrediente</h3>
        @if (!string.IsNullOrEmpty(editErrorMessage))
        {
            <p class="text-danger">@editErrorMessage</p>
        }
        <div class="detail-container">
            <div class="detail-item">
                <label>Nombre: <span class="text-danger">*</span></label>
                <input @bind="editModel.Nombre" class="form-control" />
            </div>
            <div class="detail-item">
                <label>Unidad base:</label>
                <input value="@ingredienteEnEdicion.UnidadBase" class="form-control" disabled />
            </div>
            <div class="mt-3">
                <button class="btn btn-primary" @onclick="GuardarEdicionIngrediente" disabled="@isSaving">
                    @(isSaving ? "Guardando..." : "Guardar")
                </button>
                <button class="btn btn-secondary ms-2" @onclick="CerrarEdicion">Cancelar</button>
            </div>
        </div>
        <div class="footer-spacing"></div>
    }
}

@if (showCreateForm)
{
    <h3>Nuevo ingrediente</h3>
    @if (!string.IsNullOrEmpty(createErrorMessage))
    {
        <p class="text-danger">@createErrorMessage</p>
    }
    <div class="detail-container">
        <div class="detail-item">
            <label>Nombre: <span class="text-danger">*</span></label>
            <input @bind="nuevoIngrediente.Nombre" class="form-control" />
        </div>
        <div class="detail-item">
            <label>Unidad base: <span class="text-danger">*</span></label>
            <select @bind="nuevoIngrediente.UnidadBase" class="form-control">
                @foreach (var valor in Enum.GetValues<UnidadDeMedida>())
                {
                    <option value="@valor">@valor</option>
                }
            </select>
        </div>
        <div class="mt-3">
            <button class="btn btn-primary" @onclick="GuardarIngrediente" disabled="@isSaving">
                @(isSaving ? "Guardando..." : "Guardar")
            </button>
            <button class="btn btn-secondary ms-2" @onclick="CancelarCreacion">Cancelar</button>
        </div>
    </div>
    <div class="footer-spacing"></div>
}

@code {
    private List<IngredienteResponse> ingredientes = new();
    private IngredienteResponse? ingredienteSeleccionado;
    private IngredienteResponse? ingredienteEnEdicion;
    private NuevoIngredienteModel nuevoIngrediente = new();
    private EditarIngredienteModel editModel = new();
    private bool isLoading = true;
    private bool showCreateForm = false;
    private bool showEditForm = false;
    private bool isSaving = false;
    private string? searchNombre;
    private string? errorMessage;
    private string? createErrorMessage;
    private string? editErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        await BuscarIngredientes();
    }

    private async Task BuscarIngredientes()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            ingredientes = await IngredienteService.SearchAsync(searchNombre, false);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void VerDetalle(IngredienteResponse ingrediente)
    {
        ingredienteSeleccionado = ingrediente;
        showCreateForm = false;
        showEditForm = false;
        ingredienteEnEdicion = null;
        editErrorMessage = null;
    }

    private void CerrarDetalle()
    {
        ingredienteSeleccionado = null;
    }

    private void MostrarEditar(IngredienteResponse ingrediente)
    {
        ingredienteEnEdicion = ingrediente;
        editModel = new EditarIngredienteModel
        {
            Nombre = ingrediente.Nombre
        };
        editErrorMessage = null;
        showEditForm = true;
        ingredienteSeleccionado = null;
        showCreateForm = false;
    }

    private void CerrarEdicion()
    {
        showEditForm = false;
        ingredienteEnEdicion = null;
        editModel = new EditarIngredienteModel();
        editErrorMessage = null;
    }

    private void AgregarNuevoIngrediente()
    {
        nuevoIngrediente = new NuevoIngredienteModel();
        createErrorMessage = null;
        showCreateForm = true;
        ingredienteSeleccionado = null;
        showEditForm = false;
        ingredienteEnEdicion = null;
        editErrorMessage = null;
    }

    private async Task GuardarEdicionIngrediente()
    {
        if (ingredienteEnEdicion == null) return;

        if (string.IsNullOrWhiteSpace(editModel.Nombre))
        {
            editErrorMessage = "El nombre es requerido.";
            return;
        }

        try
        {
            isSaving = true;
            editErrorMessage = null;
            var req = new EditarIngredienteRequest(editModel.Nombre);

            await IngredienteService.UpdateAsync(ingredienteEnEdicion.Id, req);
            CerrarEdicion();
            await BuscarIngredientes();
        }
        catch (ApiException ex)
        {
            editErrorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            editErrorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task EliminarIngrediente(Guid id)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", "¿Eliminar este ingrediente?");
        if (!ok) return;

        try
        {
            errorMessage = null;
            await IngredienteService.DeleteAsync(id);
            await BuscarIngredientes();
        }
        catch (ApiException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private async Task GuardarIngrediente()
    {
        if (string.IsNullOrWhiteSpace(nuevoIngrediente.Nombre))
        {
            createErrorMessage = "El nombre es requerido.";
            return;
        }

        try
        {
            isSaving = true;
            createErrorMessage = null;
            var request = new CrearIngredienteRequest(
                nuevoIngrediente.Nombre,
                nuevoIngrediente.UnidadBase);

            await IngredienteService.CreateAsync(request);
            showCreateForm = false;
            await BuscarIngredientes();
        }
        catch (ApiException ex)
        {
            createErrorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            createErrorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private void CancelarCreacion()
    {
        showCreateForm = false;
        createErrorMessage = null;
    }

    // Mutable view-model for the create form (records are immutable)
    private class NuevoIngredienteModel
    {
        public string Nombre { get; set; } = string.Empty;
        public UnidadDeMedida UnidadBase { get; set; } = UnidadDeMedida.Unidad;
    }

    // Mutable view-model for the edit form
    private class EditarIngredienteModel
    {
        public string Nombre { get; set; } = string.Empty;
    }
}
