@page "/dashboard"
@attribute [Authorize(Roles = "Administrador")]
@using Microsoft.AspNetCore.Authorization
@using GastroGestionBlazor.Contracts.Dashboard
@using GastroGestionBlazor.Contracts.Common
@inject DashboardService DashboardService

<PageTitle>Dashboard · GastroGestión</PageTitle>

<h3>Dashboard</h3>
<hr class="custom-line" />

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger" role="alert">@_error</div>
}

@if (_isLoading)
{
    <p>Cargando&hellip;</p>
}
else if (_data is not null)
{
    <div class="d-flex gap-3 flex-wrap mb-4">
        <div class="card" style="min-width:200px">
            <div class="card-body">
                <h6 class="text-muted mb-1">Pedidos</h6>
                <div class="fs-3 fw-bold">@_data.TotalPedidos</div>
            </div>
        </div>
        <div class="card" style="min-width:200px">
            <div class="card-body">
                <h6 class="text-muted mb-1">Monto total en pedidos</h6>
                <div class="fs-3 fw-bold">@_data.MontoTotalPedidos.ToString("N2")</div>
            </div>
        </div>
        <div class="card" style="min-width:200px">
            <div class="card-body">
                <h6 class="text-muted mb-1">Ingredientes en alerta</h6>
                <div class="fs-3 fw-bold @(_data.AlertasStock.Count > 0 ? "text-danger" : "")">@_data.AlertasStock.Count</div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-4 flex-wrap">
        <div style="flex:1 1 320px">
            <h5>Pedidos por estado</h5>
            @if (_data.PedidosPorEstado.Count == 0)
            {
                <p class="text-muted">Sin pedidos.</p>
            }
            else
            {
                var maxE = _data.PedidosPorEstado.Max(x => x.Cantidad);
                @foreach (var e in _data.PedidosPorEstado)
                {
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <div style="width:120px" class="text-truncate">@e.Estado</div>
                        <div style="flex:1 1 auto; background:#eee; border-radius:4px; overflow:hidden">
                            <div style="width:@(BarPct(e.Cantidad, maxE))%; background:var(--copper, #b5651d); color:#fff; padding:2px 6px; border-radius:4px; min-width:24px; text-align:right; font-size:.8rem">@e.Cantidad</div>
                        </div>
                    </div>
                }
            }
        </div>

        <div style="flex:1 1 320px">
            <h5>Platos más pedidos</h5>
            @if (_data.TopPlatos.Count == 0)
            {
                <p class="text-muted">Sin datos.</p>
            }
            else
            {
                var maxP = _data.TopPlatos.Max(x => x.Cantidad);
                @foreach (var p in _data.TopPlatos)
                {
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <div style="width:120px" class="text-truncate" title="@p.Plato">@p.Plato</div>
                        <div style="flex:1 1 auto; background:#eee; border-radius:4px; overflow:hidden">
                            <div style="width:@(BarPct(p.Cantidad, maxP))%; background:#2e7d32; color:#fff; padding:2px 6px; border-radius:4px; min-width:24px; text-align:right; font-size:.8rem">@p.Cantidad</div>
                        </div>
                    </div>
                }
            }
        </div>

        <div style="flex:1 1 280px">
            <h5>Alertas de stock</h5>
            @if (_data.AlertasStock.Count == 0)
            {
                <p class="text-muted">Sin alertas. </p>
            }
            else
            {
                <table class="table">
                    <thead><tr><th>Ingrediente</th><th class="text-end">Balance</th><th class="text-end">Umbral</th></tr></thead>
                    <tbody>
                        @foreach (var a in _data.AlertasStock)
                        {
                            <tr>
                                <td>@a.Ingrediente</td>
                                <td class="text-end text-danger fw-bold">@a.Balance.ToString("N2")</td>
                                <td class="text-end">@a.StockMinimo.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@code {
    private bool _isLoading = true;
    private string? _error;
    private DashboardResponse? _data;

    // Bar width as a percentage of the section max (min 6% so a tiny value is still visible).
    private static int BarPct(int value, int max)
        => max <= 0 ? 0 : Math.Max(6, (int)Math.Round(value * 100.0 / max));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _data = await DashboardService.GetAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }
}
