@page "/pedidos"
@attribute [Authorize(Roles = "Mozo,Administrador")]
@using Microsoft.AspNetCore.Authorization
@using GastroGestionBlazor.Contracts.Enums
@using GastroGestionBlazor.Contracts.Mesas
@using GastroGestionBlazor.Contracts.Clientes
@using GastroGestionBlazor.Contracts.Pedidos
@inject PedidoService PedidoService
@inject ClienteService ClienteService
@inject NavigationManager Navigation

<PageTitle>Pedidos · GastroGestión</PageTitle>

<h3>Pedidos</h3>
<hr class="custom-line" />

<div class="form-row">
    <button class="btn btn-primary" @onclick="NuevoPedido"><i class="fas fa-plus"></i> Nuevo pedido</button>
</div>

<div class="search-container">
    <div class="form-group">
        <label for="filtroEstado">Estado:</label>
        <select id="filtroEstado" class="form-control" @bind="_estadoFiltro" @bind:after="CargarPedidos">
            <option value="">Todos</option>
            @foreach (var e in Enum.GetValues<EstadoPedido>())
            {
                <option value="@e">@e</option>
            }
        </select>
    </div>
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <p class="text-danger">@_error</p>
}

@if (_isLoading)
{
    <p>Cargando&hellip;</p>
}
else if (_pedidos.Count == 0)
{
    <p class="text-muted">No hay pedidos@(string.IsNullOrEmpty(_estadoFiltro) ? "" : " en ese estado").</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Fecha</th>
                <th>Tipo</th>
                <th>Estado</th>
                <th>Mesa / Destino</th>
                <th>Cliente</th>
                <th class="text-end">Ítems</th>
                <th class="text-end">Total</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in _pedidos)
            {
                <tr>
                    <td>@p.CreadoEnUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@GetTipoLabel(p.Tipo)</td>
                    <td><span class="badge @EstadoBadge(p.Estado)">@p.Estado</span></td>
                    <td>@DestinoLabel(p)</td>
                    <td>@ClienteLabel(p.ClienteId)</td>
                    <td class="text-end">@p.Lineas.Sum(l => l.Cantidad)</td>
                    <td class="text-end">@FormatTotal(p)</td>
                    <td class="action-buttons">
                        <button class="btn btn-info btn-sm" @onclick="() => VerDetalle(p.Id)" title="Ver detalle"><i class="fas fa-eye"></i></button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool _isLoading = true;
    private string? _error;
    private string _estadoFiltro = "";

    private List<PedidoResponse> _pedidos = new();
    private Dictionary<Guid, string> _mesas = new();
    private Dictionary<Guid, string> _clientes = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _mesas = (await PedidoService.GetMesasAsync())
                .ToDictionary(m => m.Id, m => $"Mesa {m.Numero}");
            _clientes = (await ClienteService.GetAllAsync())
                .ToDictionary(c => c.Id, c => c.Nombre);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }

        await CargarPedidos();
    }

    private async Task CargarPedidos()
    {
        _isLoading = true;
        _error = null;
        try
        {
            _pedidos = await PedidoService.GetPedidosAsync(
                string.IsNullOrEmpty(_estadoFiltro) ? null : _estadoFiltro);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void NuevoPedido() => Navigation.NavigateTo("/pedidos/nuevo");
    private void VerDetalle(Guid id) => Navigation.NavigateTo($"/pedidos/{id}");

    private string MesaLabel(Guid? mesaId)
        => mesaId is { } id && _mesas.TryGetValue(id, out var label) ? label : "—";

    // Salon -> table; Delivery -> destination city; otherwise nothing relevant.
    private string DestinoLabel(PedidoResponse p) => p.Tipo switch
    {
        TipoPedido.Salon    => MesaLabel(p.MesaId),
        TipoPedido.Delivery => p.DireccionEntrega is { } d ? $"🛵 {d.Ciudad}" : "—",
        _                   => "—"
    };

    private string ClienteLabel(Guid? clienteId)
        => clienteId is { } id && _clientes.TryGetValue(id, out var label) ? label : "—";

    private static string FormatTotal(PedidoResponse p)
    {
        var total = p.Lineas.Sum(l => l.TotalLinea ?? 0m);
        var moneda = p.Lineas.FirstOrDefault(l => l.Moneda is not null)?.Moneda ?? "";
        return total == 0m ? "—" : $"{total:N2} {moneda}".Trim();
    }

    private static string GetTipoLabel(TipoPedido t) => t switch
    {
        TipoPedido.Salon    => "Salón",
        TipoPedido.TakeAway => "TakeAway",
        TipoPedido.Delivery => "Delivery",
        _                   => t.ToString()
    };

    private static string EstadoBadge(string estado) => estado switch
    {
        "Abierto" or "Creado"      => "bg-primary",
        "Modificado"               => "bg-secondary",
        "Preparandose"             => "bg-warning text-dark",
        "ListoParaEntregar"        => "bg-info text-dark",
        "Entregado" or "Cerrado"   => "bg-success",
        "Cancelado"                => "bg-danger",
        _                          => "bg-secondary"
    };
}
