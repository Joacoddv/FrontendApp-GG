@page "/clientes"

@using GastroGestionBlazor.Contracts.Clientes
@using GastroGestionBlazor.Contracts.Enums
@using GastroGestionBlazor.Contracts.Common
@using Microsoft.AspNetCore.Authorization
@inject ClienteService ClienteService
@inject IJSRuntime JS

<h3>Clientes</h3>
<hr class="custom-line" />

<div class="form-row">
    <button class="btn btn-primary" @onclick="AgregarNuevoCliente"><i class="fas fa-plus"></i> Nuevo cliente</button>
</div>

<div class="search-container">
    <div class="form-group">
        <label for="campoBusqueda">Filtrar por:</label>
        <select id="campoBusqueda" class="form-control">
            <option>Nombre</option>
        </select>
    </div>
    <div class="form-group">
        <label for="valorBusqueda">Valor:</label>
        <input id="valorBusqueda" class="form-control" @bind="searchNombre" placeholder="Buscar por nombre..." />
    </div>
    <div class="form-group">
        <button class="btn btn-secondary" @onclick="BuscarClientes">Buscar</button>
    </div>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <p class="text-danger">@errorMessage</p>
}

@if (isLoading)
{
    <p>Cargando...</p>
}
else if (clientes.Count == 0)
{
    <p class="text-muted">No hay clientes registrados.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Condición IVA</th>
                <th>CUIT</th>
                <th>Email</th>
                <th>Activo</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cliente in clientes)
            {
                <tr class="@(cliente.Activo ? "" : "text-muted")">
                    <td>@cliente.Nombre</td>
                    <td>@cliente.CondicionIVA</td>
                    <td>@cliente.Cuit</td>
                    <td>@cliente.Email</td>
                    <td>
                        @if (cliente.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </td>
                    <td class="action-buttons">
                        <button class="btn btn-info btn-sm" @onclick="() => VerDetalle(cliente)" title="Ver Detalle"><i class="fas fa-eye"></i></button>
                        <AuthorizeView Roles="Administrador">
                            <button class="btn btn-warning btn-sm" @onclick="() => MostrarEditar(cliente)" title="Editar"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarCliente(cliente.Id)" title="Eliminar"><i class="fas fa-trash"></i></button>
                        </AuthorizeView>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (clienteSeleccionado != null)
    {
        <h3>Detalle del cliente</h3>
        <div class="detail-container">
            <div class="detail-item">
                <label>Nombre:</label>
                <input value="@clienteSeleccionado.Nombre" disabled />
            </div>
            <div class="detail-item">
                <label>Condición IVA:</label>
                <input value="@clienteSeleccionado.CondicionIVA" disabled />
            </div>
            <div class="detail-item">
                <label>CUIT:</label>
                <input value="@clienteSeleccionado.Cuit" disabled />
            </div>
            <div class="detail-item">
                <label>Email:</label>
                <input value="@clienteSeleccionado.Email" disabled />
            </div>
            <div class="detail-item">
                <label>Estado:</label>
                <input value="@(clienteSeleccionado.Activo ? "Activo" : "Inactivo")" disabled />
            </div>
            <div class="detail-item">
                <label>Cumpleaños:</label>
                <input value="@(clienteSeleccionado.FechaNacimiento?.ToString("dd/MM/yyyy") ?? "—")" disabled />
            </div>
        </div>

        <h5 class="mt-3">Direcciones</h5>
        @if (clienteSeleccionado.Direcciones is null || clienteSeleccionado.Direcciones.Count == 0)
        {
            <p class="text-muted">Sin direcciones.</p>
        }
        else
        {
            <table class="table">
                <thead><tr><th>Dirección</th><th>Ciudad</th><th>Provincia</th><th>CP</th><th></th></tr></thead>
                <tbody>
                    @foreach (var d in clienteSeleccionado.Direcciones)
                    {
                        <tr>
                            <td>@d.Calle @d.Numero@(string.IsNullOrEmpty(d.Piso) ? "" : $", piso {d.Piso}")@(string.IsNullOrEmpty(d.Departamento) ? "" : $" dto. {d.Departamento}")</td>
                            <td>@d.Ciudad</td>
                            <td>@d.Provincia</td>
                            <td>@d.CodigoPostal</td>
                            <td class="action-buttons">
                                <button class="btn btn-danger btn-sm" title="Quitar" @onclick="() => QuitarDireccion(d.Id)"><i class="fas fa-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        @if (!string.IsNullOrEmpty(direccionError))
        {
            <p class="text-danger">@direccionError</p>
        }
        <div class="d-flex gap-2 flex-wrap align-items-end mb-2">
            <input @bind="nuevaDireccion.Calle" class="form-control" style="width:160px" placeholder="Calle *" />
            <input @bind="nuevaDireccion.Numero" class="form-control" style="width:90px" placeholder="Número *" />
            <input @bind="nuevaDireccion.Ciudad" class="form-control" style="width:140px" placeholder="Ciudad *" />
            <input @bind="nuevaDireccion.Provincia" class="form-control" style="width:140px" placeholder="Provincia *" />
            <input @bind="nuevaDireccion.CodigoPostal" class="form-control" style="width:90px" placeholder="CP *" />
            <input @bind="nuevaDireccion.Piso" class="form-control" style="width:80px" placeholder="Piso" />
            <input @bind="nuevaDireccion.Departamento" class="form-control" style="width:80px" placeholder="Dto." />
            <button class="btn btn-secondary" disabled="@isSaving" @onclick="AgregarDireccion"><i class="fas fa-plus"></i> Agregar dirección</button>
        </div>

        <div class="mt-3">
            <button class="btn btn-secondary" @onclick="CerrarDetalle">Cerrar</button>
        </div>
        <div class="footer-spacing"></div>
    }

    @if (showEditForm && clienteEnEdicion != null)
    {
        <h3>Editar cliente</h3>
        @if (!string.IsNullOrEmpty(editErrorMessage))
        {
            <p class="text-danger">@editErrorMessage</p>
        }
        <div class="detail-container">
            <div class="detail-item">
                <label>Nombre: <span class="text-danger">*</span></label>
                <input @bind="editModel.Nombre" class="form-control" />
            </div>
            <div class="detail-item">
                <label>Condición IVA: <span class="text-danger">*</span></label>
                <select @bind="editModel.CondicionIVA" class="form-control">
                    @foreach (var valor in Enum.GetValues<CondicionIVA>())
                    {
                        <option value="@valor">@valor</option>
                    }
                </select>
            </div>
            <div class="detail-item">
                <label>CUIT:</label>
                <input @bind="editModel.Cuit" class="form-control" />
            </div>
            <div class="detail-item">
                <label>Email:</label>
                <input @bind="editModel.Email" class="form-control" />
            </div>
            <div class="detail-item">
                <label>Cumpleaños:</label>
                <input type="date" @bind="editModel.FechaNacimiento" class="form-control" />
            </div>
            <div class="mt-3">
                <button class="btn btn-primary" @onclick="GuardarEdicionCliente" disabled="@isSaving">
                    @(isSaving ? "Guardando..." : "Guardar")
                </button>
                <button class="btn btn-secondary ms-2" @onclick="CerrarEdicion">Cancelar</button>
            </div>
        </div>
        <div class="footer-spacing"></div>
    }
}

@if (showCreateForm)
{
    <h3>Nuevo cliente</h3>
    @if (!string.IsNullOrEmpty(createErrorMessage))
    {
        <p class="text-danger">@createErrorMessage</p>
    }
    <div class="detail-container">
        <div class="detail-item">
            <label>Nombre: <span class="text-danger">*</span></label>
            <input @bind="nuevoCliente.Nombre" class="form-control" />
        </div>
        <div class="detail-item">
            <label>Condición IVA: <span class="text-danger">*</span></label>
            <select @bind="nuevoCliente.CondicionIVA" class="form-control">
                @foreach (var valor in Enum.GetValues<CondicionIVA>())
                {
                    <option value="@valor">@valor</option>
                }
            </select>
        </div>
        <div class="detail-item">
            <label>CUIT:</label>
            <input @bind="nuevoCliente.Cuit" class="form-control" />
        </div>
        <div class="detail-item">
            <label>Email:</label>
            <input @bind="nuevoCliente.Email" class="form-control" />
        </div>
        <div class="detail-item">
            <label>Cumpleaños:</label>
            <input type="date" @bind="nuevoCliente.FechaNacimiento" class="form-control" />
        </div>
        <div class="mt-3">
            <button class="btn btn-primary" @onclick="GuardarCliente" disabled="@isSaving">
                @(isSaving ? "Guardando..." : "Guardar")
            </button>
            <button class="btn btn-secondary ms-2" @onclick="CancelarCreacion">Cancelar</button>
        </div>
    </div>
    <div class="footer-spacing"></div>
}

@code {
    private List<ClienteResponse> clientes = new();
    private ClienteResponse? clienteSeleccionado;
    private ClienteResponse? clienteEnEdicion;
    private NuevoClienteModel nuevoCliente = new();
    private EditarClienteModel editModel = new();
    private bool isLoading = true;
    private bool showCreateForm = false;
    private bool showEditForm = false;
    private bool isSaving = false;
    private string? searchNombre;
    private string? errorMessage;
    private string? createErrorMessage;
    private string? editErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        await BuscarClientes();
    }

    private async Task BuscarClientes()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            clientes = await ClienteService.SearchAsync(searchNombre, false);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void VerDetalle(ClienteResponse cliente)
    {
        clienteSeleccionado = cliente;
        showCreateForm = false;
        showEditForm = false;
        clienteEnEdicion = null;
        editErrorMessage = null;
    }

    private void CerrarDetalle()
    {
        clienteSeleccionado = null;
    }

    private void MostrarEditar(ClienteResponse cliente)
    {
        clienteEnEdicion = cliente;
        editModel = new EditarClienteModel
        {
            Nombre = cliente.Nombre,
            CondicionIVA = cliente.CondicionIVA,
            Cuit = cliente.Cuit,
            Email = cliente.Email,
            FechaNacimiento = cliente.FechaNacimiento
        };
        editErrorMessage = null;
        showEditForm = true;
        clienteSeleccionado = null;
        showCreateForm = false;
    }

    private void CerrarEdicion()
    {
        showEditForm = false;
        clienteEnEdicion = null;
        editModel = new EditarClienteModel();
        editErrorMessage = null;
    }

    private void AgregarNuevoCliente()
    {
        nuevoCliente = new NuevoClienteModel();
        createErrorMessage = null;
        showCreateForm = true;
        clienteSeleccionado = null;
        showEditForm = false;
        clienteEnEdicion = null;
        editErrorMessage = null;
    }

    private async Task GuardarEdicionCliente()
    {
        if (clienteEnEdicion == null) return;

        if (string.IsNullOrWhiteSpace(editModel.Nombre))
        {
            editErrorMessage = "El nombre es requerido.";
            return;
        }

        try
        {
            isSaving = true;
            editErrorMessage = null;
            var req = new EditarClienteRequest(
                editModel.Nombre,
                editModel.CondicionIVA,
                string.IsNullOrWhiteSpace(editModel.Cuit) ? null : editModel.Cuit,
                string.IsNullOrWhiteSpace(editModel.Email) ? null : editModel.Email,
                editModel.FechaNacimiento);

            await ClienteService.UpdateAsync(clienteEnEdicion.Id, req);
            CerrarEdicion();
            await BuscarClientes();
        }
        catch (ApiException ex)
        {
            editErrorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            editErrorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task EliminarCliente(Guid id)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", "¿Eliminar este cliente?");
        if (!ok) return;

        try
        {
            errorMessage = null;
            await ClienteService.DeleteAsync(id);
            await BuscarClientes();
        }
        catch (ApiException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private async Task GuardarCliente()
    {
        if (string.IsNullOrWhiteSpace(nuevoCliente.Nombre))
        {
            createErrorMessage = "El nombre es requerido.";
            return;
        }

        try
        {
            isSaving = true;
            createErrorMessage = null;
            var request = new CrearClienteRequest(
                nuevoCliente.Nombre,
                nuevoCliente.CondicionIVA,
                string.IsNullOrWhiteSpace(nuevoCliente.Cuit) ? null : nuevoCliente.Cuit,
                string.IsNullOrWhiteSpace(nuevoCliente.Email) ? null : nuevoCliente.Email,
                nuevoCliente.FechaNacimiento);

            await ClienteService.CreateAsync(request);
            showCreateForm = false;
            await BuscarClientes();
        }
        catch (ApiException ex)
        {
            createErrorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            createErrorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private void CancelarCreacion()
    {
        showCreateForm = false;
        createErrorMessage = null;
    }

    // Mutable view-model for the create form (records are immutable)
    private class NuevoClienteModel
    {
        public string Nombre { get; set; } = string.Empty;
        public CondicionIVA CondicionIVA { get; set; } = CondicionIVA.ConsumidorFinal;
        public string? Cuit { get; set; }
        public string? Email { get; set; }
        public DateOnly? FechaNacimiento { get; set; }
    }

    // Mutable view-model for the edit form
    private class EditarClienteModel
    {
        public string Nombre { get; set; } = string.Empty;
        public CondicionIVA CondicionIVA { get; set; } = CondicionIVA.ConsumidorFinal;
        public string? Cuit { get; set; }
        public string? Email { get; set; }
        public DateOnly? FechaNacimiento { get; set; }
    }

    // ── Direcciones (in the detail panel) ──────────────────────────────────────
    private string? direccionError;
    private DireccionModel nuevaDireccion = new();

    private class DireccionModel
    {
        public string? Calle { get; set; }
        public string? Numero { get; set; }
        public string? Ciudad { get; set; }
        public string? Provincia { get; set; }
        public string? CodigoPostal { get; set; }
        public string? Piso { get; set; }
        public string? Departamento { get; set; }

        public void Reset() { Calle = Numero = Ciudad = Provincia = CodigoPostal = Piso = Departamento = null; }
    }

    private async Task AgregarDireccion()
    {
        if (clienteSeleccionado is null) return;
        direccionError = null;

        if (string.IsNullOrWhiteSpace(nuevaDireccion.Calle) || string.IsNullOrWhiteSpace(nuevaDireccion.Numero) ||
            string.IsNullOrWhiteSpace(nuevaDireccion.Ciudad) || string.IsNullOrWhiteSpace(nuevaDireccion.Provincia) ||
            string.IsNullOrWhiteSpace(nuevaDireccion.CodigoPostal))
        {
            direccionError = "Calle, número, ciudad, provincia y CP son obligatorios.";
            return;
        }

        try
        {
            isSaving = true;
            var req = new AgregarDireccionRequest(
                nuevaDireccion.Calle!.Trim(), nuevaDireccion.Numero!.Trim(), nuevaDireccion.Ciudad!.Trim(),
                nuevaDireccion.Provincia!.Trim(), nuevaDireccion.CodigoPostal!.Trim(),
                string.IsNullOrWhiteSpace(nuevaDireccion.Piso) ? null : nuevaDireccion.Piso!.Trim(),
                string.IsNullOrWhiteSpace(nuevaDireccion.Departamento) ? null : nuevaDireccion.Departamento!.Trim());

            var updated = await ClienteService.AgregarDireccionAsync(clienteSeleccionado.Id, req);
            if (updated is not null) clienteSeleccionado = updated;
            nuevaDireccion.Reset();
            await BuscarClientes();
        }
        catch (ApiException ex) { direccionError = ex.Message; }
        catch (Exception ex) { direccionError = ex.Message; }
        finally { isSaving = false; }
    }

    private async Task QuitarDireccion(Guid direccionId)
    {
        if (clienteSeleccionado is null) return;
        direccionError = null;
        try
        {
            var updated = await ClienteService.QuitarDireccionAsync(clienteSeleccionado.Id, direccionId);
            if (updated is not null) clienteSeleccionado = updated;
            await BuscarClientes();
        }
        catch (ApiException ex) { direccionError = ex.Message; }
        catch (Exception ex) { direccionError = ex.Message; }
    }
}
