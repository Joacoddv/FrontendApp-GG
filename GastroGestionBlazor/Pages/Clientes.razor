@page "/clientes"

@using GastroGestionBlazor.Contracts.Clientes
@using GastroGestionBlazor.Contracts.Enums
@using GastroGestionBlazor.Contracts.Common
@inject ClienteService ClienteService

<h3>Clientes</h3>
<hr class="custom-line" />

<div class="form-row">
    <button class="btn btn-primary" @onclick="AgregarNuevoCliente"><i class="fas fa-plus"></i> Nuevo cliente</button>
</div>

<div class="search-container">
    <div class="form-group">
        <label for="campoBusqueda">Filtrar por:</label>
        <select id="campoBusqueda" class="form-control" disabled title="No disponible aún">
            <option>Nombre</option>
        </select>
        <small class="text-muted">No disponible aún</small>
    </div>
    <div class="form-group">
        <label for="valorBusqueda">Valor:</label>
        <input id="valorBusqueda" class="form-control" disabled title="No disponible aún" />
    </div>
    <div class="form-group">
        <button class="btn btn-secondary" disabled title="No disponible aún">Buscar</button>
        <small class="text-muted ms-1">No disponible aún</small>
    </div>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <p class="text-danger">@errorMessage</p>
}

@if (isLoading)
{
    <p>Cargando...</p>
}
else if (clientes.Count == 0)
{
    <p class="text-muted">No hay clientes registrados.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Condición IVA</th>
                <th>CUIT</th>
                <th>Email</th>
                <th>Activo</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cliente in clientes)
            {
                <tr class="@(cliente.Activo ? "" : "text-muted")">
                    <td>@cliente.Nombre</td>
                    <td>@cliente.CondicionIVA</td>
                    <td>@cliente.Cuit</td>
                    <td>@cliente.Email</td>
                    <td>
                        @if (cliente.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </td>
                    <td class="action-buttons">
                        <button class="btn btn-info btn-sm" @onclick="() => VerDetalle(cliente)" title="Ver Detalle"><i class="fas fa-eye"></i></button>
                        <button class="btn btn-secondary btn-sm" disabled title="No disponible aún"><i class="fas fa-edit"></i></button>
                        <small class="text-muted">No disponible aún</small>
                        <button class="btn btn-secondary btn-sm" disabled title="No disponible aún"><i class="fas fa-trash"></i></button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (clienteSeleccionado != null)
    {
        <h3>Detalle del cliente</h3>
        <div class="detail-container">
            <div class="detail-item">
                <label>Nombre:</label>
                <input value="@clienteSeleccionado.Nombre" disabled />
            </div>
            <div class="detail-item">
                <label>Condición IVA:</label>
                <input value="@clienteSeleccionado.CondicionIVA" disabled />
            </div>
            <div class="detail-item">
                <label>CUIT:</label>
                <input value="@clienteSeleccionado.Cuit" disabled />
            </div>
            <div class="detail-item">
                <label>Email:</label>
                <input value="@clienteSeleccionado.Email" disabled />
            </div>
            <div class="detail-item">
                <label>Estado:</label>
                <input value="@(clienteSeleccionado.Activo ? "Activo" : "Inactivo")" disabled />
            </div>
            <div class="mt-3">
                <button class="btn btn-secondary" @onclick="CerrarDetalle">Cerrar</button>
            </div>
        </div>
        <div class="footer-spacing"></div>
    }
}

@if (showCreateForm)
{
    <h3>Nuevo cliente</h3>
    @if (!string.IsNullOrEmpty(createErrorMessage))
    {
        <p class="text-danger">@createErrorMessage</p>
    }
    <div class="detail-container">
        <div class="detail-item">
            <label>Nombre: <span class="text-danger">*</span></label>
            <input @bind="nuevoCliente.Nombre" class="form-control" />
        </div>
        <div class="detail-item">
            <label>Condición IVA: <span class="text-danger">*</span></label>
            <select @bind="nuevoCliente.CondicionIVA" class="form-control">
                @foreach (var valor in Enum.GetValues<CondicionIVA>())
                {
                    <option value="@valor">@valor</option>
                }
            </select>
        </div>
        <div class="detail-item">
            <label>CUIT:</label>
            <input @bind="nuevoCliente.Cuit" class="form-control" />
        </div>
        <div class="detail-item">
            <label>Email:</label>
            <input @bind="nuevoCliente.Email" class="form-control" />
        </div>
        <div class="mt-3">
            <button class="btn btn-primary" @onclick="GuardarCliente" disabled="@isSaving">
                @(isSaving ? "Guardando..." : "Guardar")
            </button>
            <button class="btn btn-secondary ms-2" @onclick="CancelarCreacion">Cancelar</button>
        </div>
    </div>
    <div class="footer-spacing"></div>
}

@code {
    private List<ClienteResponse> clientes = new();
    private ClienteResponse? clienteSeleccionado;
    private NuevoClienteModel nuevoCliente = new();
    private bool isLoading = true;
    private bool showCreateForm = false;
    private bool isSaving = false;
    private string? errorMessage;
    private string? createErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        await CargarClientes();
    }

    private async Task CargarClientes()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            clientes = await ClienteService.GetAllAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void VerDetalle(ClienteResponse cliente)
    {
        clienteSeleccionado = cliente;
        showCreateForm = false;
    }

    private void CerrarDetalle()
    {
        clienteSeleccionado = null;
    }

    private void AgregarNuevoCliente()
    {
        nuevoCliente = new NuevoClienteModel();
        createErrorMessage = null;
        showCreateForm = true;
        clienteSeleccionado = null;
    }

    private async Task GuardarCliente()
    {
        if (string.IsNullOrWhiteSpace(nuevoCliente.Nombre))
        {
            createErrorMessage = "El nombre es requerido.";
            return;
        }

        try
        {
            isSaving = true;
            createErrorMessage = null;
            var request = new CrearClienteRequest(
                nuevoCliente.Nombre,
                nuevoCliente.CondicionIVA,
                string.IsNullOrWhiteSpace(nuevoCliente.Cuit) ? null : nuevoCliente.Cuit,
                string.IsNullOrWhiteSpace(nuevoCliente.Email) ? null : nuevoCliente.Email);

            await ClienteService.CreateAsync(request);
            showCreateForm = false;
            await CargarClientes();
        }
        catch (ApiException ex)
        {
            createErrorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            createErrorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private void CancelarCreacion()
    {
        showCreateForm = false;
        createErrorMessage = null;
    }

    // Mutable view-model for the create form (records are immutable)
    private class NuevoClienteModel
    {
        public string Nombre { get; set; } = string.Empty;
        public CondicionIVA CondicionIVA { get; set; } = CondicionIVA.ConsumidorFinal;
        public string? Cuit { get; set; }
        public string? Email { get; set; }
    }
}
