@page "/pedidos/{Id:guid}"
@attribute [Authorize(Roles = "Mozo,Cajero,Administrador")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using GastroGestionBlazor.Contracts.Enums
@using GastroGestionBlazor.Contracts.Platos
@using GastroGestionBlazor.Contracts.Pedidos
@using GastroGestionBlazor.Contracts.Common
@inject PedidoService PedidoService
@inject PlatoService PlatoService
@inject ClienteService ClienteService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthProvider
@inject IJSRuntime JS

<PageTitle>Detalle de pedido · GastroGestión</PageTitle>

<h3>Detalle de pedido</h3>
<hr class="custom-line" />

<div class="form-row">
    <button class="btn btn-secondary" @onclick="Volver"><i class="fas fa-arrow-left"></i> Volver a pedidos</button>
</div>

@if (_isLoading)
{
    <p>Cargando&hellip;</p>
}
else if (!string.IsNullOrEmpty(_error))
{
    <p class="text-danger">@_error</p>
}
else if (_pedido is null)
{
    <p class="text-muted">No se encontró el pedido.</p>
}
else
{
    <div class="detail-container">
        <div class="detail-item"><label>Tipo</label><div>@GetTipoLabel(_pedido.Tipo)</div></div>
        <div class="detail-item"><label>Estado</label><div><span class="badge @EstadoBadge(_pedido.Estado)">@_pedido.Estado</span></div></div>
        <div class="detail-item"><label>Fecha</label><div>@_pedido.CreadoEnUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div></div>
        <div class="detail-item"><label>Cliente</label><div>@ClienteLabel(_pedido.ClienteId)</div></div>

        @if (_pedido.Tipo == TipoPedido.Salon)
        {
            <div class="detail-item"><label>Mesa</label><div>@MesaLabel(_pedido.MesaId)</div></div>
        }
        else if (_pedido.Tipo == TipoPedido.Delivery && _pedido.DireccionEntrega is { } dir)
        {
            <div class="detail-item" style="flex-basis:100%">
                <label>Dirección de entrega</label>
                <div>
                    @FormatDireccion(dir)
                    <a class="btn btn-outline-secondary btn-sm ms-2" target="_blank" rel="noopener"
                       href="@MapsUrl(dir)" title="Abrir en pantalla completa">
                        <i class="fas fa-map-location-dot"></i> Pantalla completa
                    </a>
                </div>
                <iframe class="mt-2"
                        style="width:100%; height:300px; border:0; border-radius:8px;"
                        src="@MapsEmbedUrl(dir)"
                        title="Mapa de la dirección de entrega"
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"
                        allowfullscreen></iframe>
            </div>
        }
    </div>

    <h5 class="mt-4">Platos</h5>
    @if (!string.IsNullOrEmpty(_lineaError))
    {
        <div class="alert alert-danger" role="alert">@_lineaError</div>
    }
    @if (_pedido.Lineas.Count == 0)
    {
        <p class="text-muted">El pedido no tiene líneas.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Plato</th>
                    <th class="text-end">Cant.</th>
                    <th class="text-end">Precio unit.</th>
                    <th class="text-end">IVA</th>
                    <th class="text-end">Subtotal</th>
                    <th class="text-end">Total</th>
                    <th>Observaciones</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var l in _pedido.Lineas)
                {
                    <tr>
                        <td>@PlatoLabel(l.PlatoId)</td>
                        @if (_editId == l.Id)
                        {
                            <td class="text-end" style="width:90px">
                                <input type="number" min="1" step="1" @bind="_editCant" class="form-control form-control-sm text-end" />
                            </td>
                            <td class="text-end">@Money(l.PrecioUnitario, l.Moneda)</td>
                            <td class="text-end">@(l.IvaTasa is { } t ? t.ToString("P1") : "—")</td>
                            <td class="text-end">@Money(l.SubtotalLinea, l.Moneda)</td>
                            <td class="text-end">@Money(l.TotalLinea, l.Moneda)</td>
                            <td><input @bind="_editObs" class="form-control form-control-sm" placeholder="Observaciones" /></td>
                            <td class="action-buttons">
                                <button class="btn btn-success btn-sm" disabled="@_savingLinea" @onclick="() => GuardarLinea(l)" title="Guardar"><i class="fas fa-check"></i></button>
                                <button class="btn btn-secondary btn-sm" disabled="@_savingLinea" @onclick="CancelarEdicion" title="Cancelar"><i class="fas fa-times"></i></button>
                            </td>
                        }
                        else
                        {
                            <td class="text-end">@l.Cantidad</td>
                            <td class="text-end">@Money(l.PrecioUnitario, l.Moneda)</td>
                            <td class="text-end">@(l.IvaTasa is { } t ? t.ToString("P1") : "—")</td>
                            <td class="text-end">@Money(l.SubtotalLinea, l.Moneda)</td>
                            <td class="text-end">@Money(l.TotalLinea, l.Moneda)</td>
                            <td>@(string.IsNullOrWhiteSpace(l.Observaciones) ? "—" : l.Observaciones)</td>
                            <td class="action-buttons">
                                @if (_puedeEditarLineas && _editId is null)
                                {
                                    <button class="btn btn-warning btn-sm" @onclick="() => IniciarEdicion(l)" title="Editar línea"><i class="fas fa-edit"></i></button>
                                    @if (_pedido.Lineas.Count > 1)
                                    {
                                        <button class="btn btn-danger btn-sm" disabled="@_savingLinea" @onclick="() => QuitarLinea(l)" title="Quitar línea"><i class="fas fa-trash"></i></button>
                                    }
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="5" class="text-end">Total del pedido</th>
                    <th class="text-end">@TotalPedido()</th>
                    <th></th>
                    <th></th>
                </tr>
            </tfoot>
        </table>
    }

    @if (_puedeEditarLineas)
    {
        <div class="d-flex gap-2 flex-wrap align-items-end mt-2 mb-2" style="max-width:760px">
            <div style="flex:1 1 auto; min-width:200px">
                <label class="form-label mb-1">Agregar plato</label>
                <select @bind="_addPlatoId" class="form-select form-select-sm">
                    <option value="@Guid.Empty">— Plato —</option>
                    @foreach (var p in _platosActivos)
                    {
                        <option value="@p.Id">@p.Nombre (@p.PrecioBase.ToString("N2") @p.Moneda)</option>
                    }
                </select>
            </div>
            <div style="width:90px">
                <label class="form-label mb-1">Cant.</label>
                <input type="number" min="1" step="1" @bind="_addCant" class="form-control form-control-sm" />
            </div>
            <div style="flex:1 1 auto; min-width:160px">
                <label class="form-label mb-1">Observaciones</label>
                <input @bind="_addObs" class="form-control form-control-sm" placeholder="Opcional" />
            </div>
            <button class="btn btn-primary btn-sm" disabled="@_adding" @onclick="AgregarPlato">
                <i class="fas fa-plus"></i> @(_adding ? "Agregando..." : "Agregar")
            </button>
        </div>
        @if (!string.IsNullOrEmpty(_addError))
        {
            <div class="alert alert-danger" role="alert">@_addError</div>
        }
    }

    @if (Permitidas.Count > 0)
    {
        <h5 class="mt-4">Cambiar estado</h5>
        @if (!string.IsNullOrEmpty(_transError))
        {
            <div class="alert alert-danger" role="alert">@_transError</div>
        }
        <div class="d-flex gap-2 flex-wrap">
            @foreach (var destino in Permitidas)
            {
                <button class="btn @BtnClass(destino)" disabled="@_transitioning"
                        @onclick="() => Transicionar(destino)">
                    @TransicionLabel(destino)
                </button>
            }
        </div>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _isLoading = true;
    private string? _error;
    private PedidoResponse? _pedido;

    private string? _rol;
    private string? _transError;
    private bool _transitioning;

    private Guid? _editId;
    private int _editCant = 1;
    private string? _editObs;
    private string? _lineaError;
    private bool _savingLinea;

    private List<PlatoResponse> _platosActivos = new();
    private Guid _addPlatoId = Guid.Empty;
    private int _addCant = 1;
    private string? _addObs;
    private string? _addError;
    private bool _adding;

    private Dictionary<Guid, string> _platos = new();
    private Dictionary<Guid, string> _mesas = new();
    private Dictionary<Guid, string> _clientes = new();

    private EstadoPedido? _estadoActual =>
        _pedido is not null && Enum.TryParse<EstadoPedido>(_pedido.Estado, out var e) ? e : null;

    private IReadOnlyList<EstadoPedido> Permitidas =>
        _pedido is not null && _estadoActual is { } actual
            ? PedidoTransiciones.Permitidas(_pedido.Tipo, actual, _rol)
            : Array.Empty<EstadoPedido>();

    // Lines are editable while the order is still being assembled — before the kitchen works it.
    // The backend re-checks the per-line OT lock and rejects edits to lines already in prep.
    private bool _puedeEditarLineas =>
        _estadoActual is EstadoPedido.Abierto or EstadoPedido.Creado or EstadoPedido.Modificado;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            _rol = authState.User.FindFirst(ClaimTypes.Role)?.Value;

            var platos = await PlatoService.GetAllAsync();
            _platos = platos.ToDictionary(p => p.Id, p => p.Nombre);
            _platosActivos = platos.Where(p => p.Activo).ToList();
            _mesas = (await PedidoService.GetMesasAsync()).ToDictionary(m => m.Id, m => $"Mesa {m.Numero}");
            _clientes = (await ClienteService.GetAllAsync()).ToDictionary(c => c.Id, c => c.Nombre);
            _pedido = await PedidoService.GetPedidoByIdAsync(Id);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void Volver() => Navigation.NavigateTo("/pedidos");

    private void IniciarEdicion(LineaPedidoResponse l)
    {
        _lineaError = null;
        _editId = l.Id;
        _editCant = l.Cantidad;
        _editObs = l.Observaciones;
    }

    private void CancelarEdicion()
    {
        _editId = null;
        _lineaError = null;
    }

    private async Task QuitarLinea(LineaPedidoResponse l)
    {
        _lineaError = null;
        var ok = await JS.InvokeAsync<bool>("confirm", "¿Quitar esta línea del pedido?");
        if (!ok)
            return;

        _savingLinea = true;
        try
        {
            var updated = await PedidoService.QuitarLineaAsync(_pedido!.Id, l.Id);
            if (updated is not null)
                _pedido = updated;
        }
        catch (ApiException ex)
        {
            _lineaError = ex.Message;
        }
        catch (Exception ex)
        {
            _lineaError = ex.Message;
        }
        finally
        {
            _savingLinea = false;
        }
    }

    private async Task AgregarPlato()
    {
        _addError = null;
        if (_addPlatoId == Guid.Empty)
        {
            _addError = "Elegí un plato.";
            return;
        }
        if (_addCant <= 0)
        {
            _addError = "La cantidad debe ser mayor a cero.";
            return;
        }

        _adding = true;
        try
        {
            // Add the line, confirm its price snapshot, then route it to the kitchen with its own OT.
            var lineaId = await PedidoService.AgregarLineaAsync(
                _pedido!.Id,
                new AgregarLineaRequest(_addPlatoId, _addCant,
                    string.IsNullOrWhiteSpace(_addObs) ? null : _addObs!.Trim()));
            await PedidoService.ConfirmarPrecioLineaAsync(_pedido.Id, lineaId);
            var updated = await PedidoService.GenerarOrdenTrabajoLineaAsync(_pedido.Id, lineaId);
            if (updated is not null)
                _pedido = updated;

            _addPlatoId = Guid.Empty;
            _addCant = 1;
            _addObs = null;
        }
        catch (ApiException ex)
        {
            _addError = ex.Message;
        }
        catch (Exception ex)
        {
            _addError = ex.Message;
        }
        finally
        {
            _adding = false;
        }
    }

    private async Task GuardarLinea(LineaPedidoResponse l)
    {
        _lineaError = null;
        if (_editCant <= 0)
        {
            _lineaError = "La cantidad debe ser mayor a cero.";
            return;
        }

        _savingLinea = true;
        try
        {
            var updated = await PedidoService.ActualizarLineaAsync(
                _pedido!.Id, l.Id, _editCant,
                string.IsNullOrWhiteSpace(_editObs) ? null : _editObs!.Trim());
            if (updated is not null)
                _pedido = updated;
            _editId = null;
        }
        catch (ApiException ex)
        {
            _lineaError = ex.Message;
        }
        catch (Exception ex)
        {
            _lineaError = ex.Message;
        }
        finally
        {
            _savingLinea = false;
        }
    }

    private async Task Transicionar(EstadoPedido destino)
    {
        _transError = null;

        if (destino == EstadoPedido.Cancelado)
        {
            var ok = await JS.InvokeAsync<bool>("confirm", "¿Cancelar este pedido? No se puede deshacer.");
            if (!ok)
                return;
        }

        _transitioning = true;
        try
        {
            var updated = await PedidoService.TransicionarEstadoAsync(_pedido!.Id, destino);
            if (updated is not null)
                _pedido = updated;
        }
        catch (ApiException ex)
        {
            _transError = ex.Message;
        }
        catch (Exception ex)
        {
            _transError = ex.Message;
        }
        finally
        {
            _transitioning = false;
        }
    }

    private static string TransicionLabel(EstadoPedido destino) => destino switch
    {
        EstadoPedido.Cerrado           => "Cerrar pedido",
        EstadoPedido.Cancelado         => "Cancelar",
        EstadoPedido.Modificado        => "Marcar modificado",
        EstadoPedido.Preparandose      => "Enviar a preparación",
        EstadoPedido.ListoParaEntregar => "Marcar listo",
        EstadoPedido.Entregado         => "Marcar entregado",
        _                              => destino.ToString()
    };

    private static string BtnClass(EstadoPedido destino)
        => destino == EstadoPedido.Cancelado ? "btn-danger" : "btn-primary";

    private string PlatoLabel(Guid platoId)
        => _platos.TryGetValue(platoId, out var n) ? n : "(plato)";

    private string MesaLabel(Guid? mesaId)
        => mesaId is { } id && _mesas.TryGetValue(id, out var label) ? label : "—";

    private string ClienteLabel(Guid? clienteId)
        => clienteId is { } id && _clientes.TryGetValue(id, out var label) ? label : "Sin cliente";

    private string TotalPedido()
    {
        var total = _pedido!.Lineas.Sum(l => l.TotalLinea ?? 0m);
        var moneda = _pedido.Lineas.FirstOrDefault(l => l.Moneda is not null)?.Moneda ?? "";
        return total == 0m ? "—" : $"{total:N2} {moneda}".Trim();
    }

    private static string Money(decimal? monto, string? moneda)
        => monto is { } m ? $"{m:N2} {moneda}".Trim() : "—";

    // Address string used to geocode the delivery point on Google Maps.
    private static string AddressQuery(DireccionEntregaResponse d)
        => $"{d.Calle} {d.Numero}, {d.Ciudad}, {d.Provincia} {d.CodigoPostal}";

    // Keyless Google Maps web link (no API key / billing needed) — opens full screen in a new tab.
    private static string MapsUrl(DireccionEntregaResponse d)
        => "https://www.google.com/maps/search/?api=1&query=" + Uri.EscapeDataString(AddressQuery(d));

    // Keyless Google Maps embed (no API key / billing needed) for the inline iframe.
    private static string MapsEmbedUrl(DireccionEntregaResponse d)
        => "https://maps.google.com/maps?q=" + Uri.EscapeDataString(AddressQuery(d)) + "&z=15&output=embed";

    private static string FormatDireccion(DireccionEntregaResponse d)
    {
        var linea = $"{d.Calle} {d.Numero}";
        if (!string.IsNullOrWhiteSpace(d.Piso)) linea += $", piso {d.Piso}";
        if (!string.IsNullOrWhiteSpace(d.Departamento)) linea += $" dto. {d.Departamento}";
        return $"{linea} — {d.Ciudad}, {d.Provincia} (CP {d.CodigoPostal})";
    }

    private static string GetTipoLabel(TipoPedido t) => t switch
    {
        TipoPedido.Salon    => "Salón",
        TipoPedido.TakeAway => "TakeAway",
        TipoPedido.Delivery => "Delivery",
        _                   => t.ToString()
    };

    private static string EstadoBadge(string estado) => estado switch
    {
        "Abierto" or "Creado"    => "bg-primary",
        "Modificado"             => "bg-secondary",
        "Preparandose"           => "bg-warning text-dark",
        "ListoParaEntregar"      => "bg-info text-dark",
        "Entregado" or "Cerrado" => "bg-success",
        "Cancelado"              => "bg-danger",
        _                        => "bg-secondary"
    };
}
