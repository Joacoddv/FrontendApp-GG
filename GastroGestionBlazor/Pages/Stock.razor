@page "/stock"
@attribute [Authorize(Roles = "Administrador")]
@using Microsoft.AspNetCore.Authorization
@using GastroGestionBlazor.Contracts.Enums
@using GastroGestionBlazor.Contracts.Stock
@using GastroGestionBlazor.Contracts.Common
@using GastroGestionBlazor.Contracts.Proveedores
@inject StockService StockService
@inject ProveedorService ProveedorService

<PageTitle>Stock · GastroGestión</PageTitle>

<h3>Stock</h3>
<hr class="custom-line" />

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger" role="alert">@_error</div>
}
@if (!string.IsNullOrEmpty(_ok))
{
    <div class="alert alert-success" role="alert">@_ok</div>
}

@if (EnAlerta.Count > 0)
{
    <div class="alert alert-warning" role="alert">
        <i class="fas fa-triangle-exclamation"></i>
        <strong>@EnAlerta.Count</strong> ingrediente@(EnAlerta.Count == 1 ? "" : "s") en alerta de stock:
        @string.Join(", ", EnAlerta.Select(b => b.Nombre))
    </div>
}

<div class="search-container">
    <div class="form-group">
        <label>Ingrediente</label>
        <select class="form-control" @bind="_movIngredienteId">
            <option value="@Guid.Empty">— Elegir —</option>
            @foreach (var b in _balances)
            {
                <option value="@b.IngredienteId">@b.Nombre</option>
            }
        </select>
    </div>
    <div class="form-group">
        <label>Movimiento</label>
        <select class="form-control" @bind="_movTipo">
            <option value="@TipoMovimientoStock.Compra">Compra (ingreso)</option>
            <option value="@TipoMovimientoStock.Merma">Merma / desperdicio (egreso)</option>
            <option value="@TipoMovimientoStock.Ajuste">Ajuste (ingreso)</option>
        </select>
    </div>
    <div class="form-group">
        <label>Cantidad</label>
        <input type="number" min="0" step="0.01" class="form-control" @bind="_movCantidad" placeholder="Cantidad" />
    </div>
    @if (_movTipo == TipoMovimientoStock.Compra)
    {
        <div class="form-group">
            <label>Proveedor</label>
            <select class="form-control" @bind="_movProveedorId">
                <option value="@Guid.Empty">— Sin proveedor —</option>
                @foreach (var p in _proveedores)
                {
                    <option value="@p.Id">@p.Nombre</option>
                }
            </select>
        </div>
    }
    <div class="form-group">
        <button class="btn btn-primary" disabled="@_saving" @onclick="Registrar">
            @(_saving ? "Registrando..." : "Registrar movimiento")
        </button>
    </div>
</div>

@if (_isLoading)
{
    <p>Cargando&hellip;</p>
}
else if (_balances.Count == 0)
{
    <p class="text-muted">No hay ingredientes.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Ingrediente</th>
                <th>Unidad</th>
                <th class="text-end">Balance</th>
                <th class="text-end">Umbral</th>
                <th>Estado</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in _balances)
            {
                <tr class="@(b.Activo ? "" : "text-muted")">
                    <td>@b.Nombre</td>
                    <td>@b.Unidad</td>
                    <td class="text-end @(b.Balance <= b.StockMinimo ? "text-danger fw-bold" : "")">@b.Balance.ToString("N2")</td>
                    <td class="text-end">
                        <div class="d-flex gap-1 justify-content-end align-items-center">
                            <input type="number" min="0" step="0.01" class="form-control form-control-sm text-end" style="width:90px"
                                   @bind="_umbralEdits[b.IngredienteId]" />
                            <button class="btn btn-secondary btn-sm" title="Guardar umbral" @onclick="() => GuardarUmbral(b.IngredienteId)"><i class="fas fa-check"></i></button>
                        </div>
                    </td>
                    <td>
                        @if (b.Balance <= 0)
                        {
                            <span class="badge bg-danger">Sin stock</span>
                        }
                        else if (b.EnAlerta)
                        {
                            <span class="badge bg-warning text-dark">En alerta</span>
                        }
                        else
                        {
                            <span class="badge bg-success">OK</span>
                        }
                    </td>
                    <td class="action-buttons">
                        <button class="btn btn-info btn-sm" @onclick="() => VerMovimientos(b)" title="Ver movimientos"><i class="fas fa-clock-rotate-left"></i></button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (_histIngrediente is not null)
    {
        <div class="detail-container" style="flex-direction:column; align-items:stretch">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="mb-0">Movimientos — @_histIngrediente.Nombre</h5>
                <button class="btn btn-secondary btn-sm" @onclick="CerrarMovimientos"><i class="fas fa-times"></i> Cerrar</button>
            </div>
            @if (_histLoading)
            {
                <p class="text-muted">Cargando&hellip;</p>
            }
            else if (_movimientos.Count == 0)
            {
                <p class="text-muted">Sin movimientos.</p>
            }
            else
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Movimiento</th>
                            <th class="text-end">Cantidad</th>
                            <th>Proveedor</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in _movimientos)
                        {
                            <tr>
                                <td>@m.FechaMovimiento.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                <td><span class="badge @TipoBadge(m.Tipo)">@TipoLabel(m.Tipo)</span></td>
                                <td class="text-end @(m.Cantidad < 0 ? "text-danger" : "text-success")">@m.Cantidad.ToString("N2")</td>
                                <td>@ProveedorNombre(m.ProveedorId)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
}

@code {
    private bool _isLoading = true;
    private bool _saving;
    private string? _error;
    private string? _ok;

    private List<IngredienteBalanceResponse> _balances = new();

    private Guid _movIngredienteId = Guid.Empty;
    private TipoMovimientoStock _movTipo = TipoMovimientoStock.Compra;
    private decimal _movCantidad;
    private Guid _movProveedorId = Guid.Empty;

    private List<ProveedorResponse> _proveedores = new();
    private Dictionary<Guid, string> _provById = new();

    private IngredienteBalanceResponse? _histIngrediente;
    private List<MovimientoStockResponse> _movimientos = new();
    private bool _histLoading;

    private readonly Dictionary<Guid, decimal> _umbralEdits = new();

    private List<IngredienteBalanceResponse> EnAlerta => _balances.Where(b => b.EnAlerta).ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _proveedores = await ProveedorService.GetAllAsync();
            _provById = _proveedores.ToDictionary(p => p.Id, p => p.Nombre);
        }
        catch { /* proveedores are optional context for the Compra picker/history */ }

        await CargarBalances();
    }

    private string ProveedorNombre(Guid? id)
        => id is { } pid && _provById.TryGetValue(pid, out var n) ? n : "—";

    private async Task CargarBalances()
    {
        _isLoading = true;
        _error = null;
        try
        {
            _balances = await StockService.GetBalancesAsync();
            foreach (var b in _balances)
                _umbralEdits[b.IngredienteId] = b.StockMinimo;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task VerMovimientos(IngredienteBalanceResponse ingrediente)
    {
        _histIngrediente = ingrediente;
        _histLoading = true;
        _movimientos = new();
        try
        {
            _movimientos = await StockService.GetMovimientosAsync(ingrediente.IngredienteId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _histLoading = false;
        }
    }

    private void CerrarMovimientos() => _histIngrediente = null;

    private async Task GuardarUmbral(Guid ingredienteId)
    {
        _error = null;
        _ok = null;
        try
        {
            var valor = _umbralEdits.TryGetValue(ingredienteId, out var v) ? v : 0m;
            await StockService.SetStockMinimoAsync(ingredienteId, valor);
            _ok = "Umbral de stock actualizado.";
            await CargarBalances();
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private static string TipoLabel(TipoMovimientoStock t) => t switch
    {
        TipoMovimientoStock.Compra                => "Compra",
        TipoMovimientoStock.Consumo               => "Consumo",
        TipoMovimientoStock.Ajuste                => "Ajuste",
        TipoMovimientoStock.Reserva               => "Reserva",
        TipoMovimientoStock.LiberacionReserva     => "Liberación de reserva",
        TipoMovimientoStock.DevolucionCancelacion => "Devolución",
        TipoMovimientoStock.Merma                 => "Merma",
        _                                         => t.ToString()
    };

    private static string TipoBadge(TipoMovimientoStock t) => t switch
    {
        TipoMovimientoStock.Compra or TipoMovimientoStock.LiberacionReserva
            or TipoMovimientoStock.DevolucionCancelacion => "bg-success",
        TipoMovimientoStock.Merma                        => "bg-danger",
        TipoMovimientoStock.Consumo or TipoMovimientoStock.Reserva => "bg-secondary",
        TipoMovimientoStock.Ajuste                       => "bg-info text-dark",
        _                                                => "bg-secondary"
    };

    private async Task Registrar()
    {
        _error = null;
        _ok = null;

        if (_movIngredienteId == Guid.Empty)
        {
            _error = "Elegí un ingrediente.";
            return;
        }
        if (_movCantidad <= 0)
        {
            _error = "La cantidad debe ser mayor a cero.";
            return;
        }

        _saving = true;
        try
        {
            // Proveedor only applies to a purchase.
            Guid? proveedorId = _movTipo == TipoMovimientoStock.Compra && _movProveedorId != Guid.Empty
                ? _movProveedorId
                : null;

            await StockService.RegistrarMovimientoAsync(_movIngredienteId, _movTipo, _movCantidad, proveedorId);
            _ok = $"Movimiento registrado: {_movTipo} de {_movCantidad:N2}.";
            _movCantidad = 0;
            _movProveedorId = Guid.Empty;
            await CargarBalances();

            // Keep an open history panel in sync if it shows the affected ingredient.
            if (_histIngrediente is not null && _histIngrediente.IngredienteId == _movIngredienteId)
                _movimientos = await StockService.GetMovimientosAsync(_movIngredienteId);
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }
}
